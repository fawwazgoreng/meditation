{
    "compilerOptions": {
        "target": "ES2022",
        "types": ["node"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "outDir": "dist",
        "rootDir": "."
    },
    "include": ["src/**/*", "api/**/*"]
}